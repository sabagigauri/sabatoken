# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# Alchemy HTTPS RPC URL for Sepolia
# Example: https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY
ALCHEMY_RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_API_KEY_HERE

# Your wallet private key (no 0x prefix needed, but it works either way)
# Export from MetaMask: Account Details → Export Private Key
PRIVATE_KEY=YOUR_PRIVATE_KEY_HERE
